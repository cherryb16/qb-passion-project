<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip center" data-tip="Rank">Rk</th> <th aria-label="Player" data-stat="name_display" scope="col" class=" poptip sort_default_asc center">Player</th> <th aria-label="Age" data-stat="age" scope="col" class=" poptip center" data-tip="As of Dec. 31 of the season in question.">Age</th> <th aria-label="Team" data-stat="team_name_abbr" scope="col" class=" poptip sort_default_asc center">Team</th> <th aria-label="Pos" data-stat="pos" scope="col" class=" poptip center" data-tip="Position">Pos</th> <th aria-label="G" data-stat="games" scope="col" class=" poptip center" data-tip="Games played">G</th> <th aria-label="GS" data-stat="games_started" scope="col" class=" poptip center" data-tip="Games started as an offensive or defensive player">GS</th> <th aria-label="QBrec" data-stat="qb_rec" scope="col" class=" poptip center" data-tip="Team record in games started by this QB (regular season)">QBrec</th> <th aria-label="Cmp" data-stat="pass_cmp" scope="col" class=" poptip center" data-tip="Passes completed">Cmp</th> <th aria-label="Att" data-stat="pass_att" scope="col" class=" poptip center" data-tip="Passes attempted">Att</th> <th aria-label="Cmp%" data-stat="pass_cmp_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Passes Completed&lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">Cmp%</th> <th aria-label="Yds" data-stat="pass_yds" scope="col" class=" poptip sort_col center" data-tip="Yards Gained by Passing&lt;br&gt;For teams, sack yardage is deducted from this total">Yds</th> <th aria-label="TD" data-stat="pass_td" scope="col" class=" poptip center" data-tip="Passing Touchdowns">TD</th> <th aria-label="TD%" data-stat="pass_td_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Touchdowns Thrown when Attempting to Pass &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">TD%</th> <th aria-label="Int" data-stat="pass_int" scope="col" class=" poptip center" data-tip="Interceptions thrown">Int</th> <th aria-label="Int%" data-stat="pass_int_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Times Intercepted when Attempting to Pass &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader.&lt;br /&gt;" data-filter="1" data-name="">Int%</th> <th aria-label="1D" data-stat="pass_first_down" scope="col" class=" poptip center" data-tip="First downs passing">1D</th> <th aria-label="Succ%" data-stat="pass_success" scope="col" class=" poptip hide_non_quals center" data-tip="Passing Success Rate&lt;br /&gt;A successful pass gains at least 40% of yards required on 1st down, 60% of yards required on 2nd down, and 100% on 3rd or 4th down. Denominator is pass attempts + times sacked." data-filter="1" data-name="">Succ%</th> <th aria-label="Lng" data-stat="pass_long" scope="col" class=" poptip center" data-tip="Longest Completed Pass Thrown (complete since 1975)">Lng</th> <th aria-label="Y/A" data-stat="pass_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Yards gained per pass attempt &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">Y/A</th> <th aria-label="AY/A" data-stat="pass_adj_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Adjusted Yards gained per pass attempt&lt;br /&gt;(Passing Yards + 20 * Passing TD - 45 * Interceptions) / (Passes Attempted)&lt;br /&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">AY/A</th> <th aria-label="Y/C" data-stat="pass_yds_per_cmp" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Yards gained per pass completion&lt;/b&gt; (Passing Yards) / (Passes Completed)&lt;br /&gt;Minimum 14 pass attempts per schedule game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Y/C</th> <th aria-label="Y/G" data-stat="pass_yds_per_g" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Yards gained per game played&lt;/b&gt;&lt;br&gt;Minimum half a game played per scheduled game to qualify as leader.&lt;br&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Y/G</th> <th aria-label="Rate" data-stat="pass_rating" scope="col" class=" poptip hide_non_quals center" data-tip="Passer Rating, &lt;a href='https://www.pro-football-reference.com/about/glossary.htm'&gt;see glossary&lt;/a&gt; for details&lt;br&gt;Different ratings are used by the NFL and NCAA.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader, minimum 150 pass attempts for playoffs leader." data-filter="1" data-name="">Rate</th> <th aria-label="QBR" data-stat="qbr" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;QBR&lt;/b&gt;&lt;br /&gt;ESPN s Total Quarterback Rating, calculated since 2006" data-filter="1" data-name="">QBR</th> <th aria-label="Sk" data-stat="pass_sacked" scope="col" class=" poptip center" data-tip="Times sacked (first recorded in 1969, player per game since 1981)">Sk</th> <th aria-label="Yds" data-stat="pass_sacked_yds" scope="col" class=" poptip center" data-tip="Yards lost due to sacks (first recorded in 1969, player per game since 1981)">Yds</th> <th aria-label="Sk%" data-stat="pass_sacked_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Time Sacked when Attempting to Pass: Times Sacked / (Passes Attempted + Times Sacked)&lt;br&gt;Minimum 14 attempts + sacks per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Sk%</th> <th aria-label="NY/A" data-stat="pass_net_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Net Yards gained per pass attempt&lt;br /&gt;(Passing Yards - Sack Yards) / (Passes Attempted + Times Sacked)&lt;br /&gt;Minimum 14 attempts per schedule game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">NY/A</th> <th aria-label="ANY/A" data-stat="pass_adj_net_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Adjusted Net Yards per Pass Attempt&lt;/b&gt;&lt;br&gt;(Passing Yards - Sack Yards + (20 * Passing TD) - (45 * Interceptions)) / (Passes Attempted + Times Sacked)&lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">ANY/A</th> <th aria-label="4QC" data-stat="comebacks" scope="col" class=" poptip center" data-tip="Comebacks led by quarterback.&lt;br /&gt;Must be an offensive scoring drive in the 4th quarter, with the team trailing by one score, though not necessarily a drive to take the lead. Only games ending in a win or tie are included.">4QC</th> <th aria-label="GWD" data-stat="gwd" scope="col" class=" poptip center" data-tip="Game-winning drives led by quarterback.&lt;br /&gt;Must be an offensive scoring drive in the 4th quarter or overtime that puts the winning team ahead for the last time.">GWD</th> 