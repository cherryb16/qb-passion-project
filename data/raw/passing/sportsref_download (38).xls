<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr class="over_header"> <th aria-label=" " data-stat="header_empty_0" colspan="7" class=" poptip over_header center" style="left: -132px; position: sticky; text-align: right; z-index: 20; border-right: 1px solid rgb(148, 150, 152);"></th> <th aria-label="Passing" data-stat="header_pass" colspan="2" class="poptip over_header center not_sticky">Passing</th> <th aria-label="Air Yards" data-stat="header_air_yards" colspan="7" class="poptip over_header center not_sticky">Air Yards</th> <th aria-label="Accuracy" data-stat="header_accuracy" colspan="9" class="poptip over_header center not_sticky">Accuracy</th> <th aria-label="Pressure" data-stat="header_pressure" colspan="8" class="poptip over_header center not_sticky">Pressure</th> <th aria-label="RPO" data-stat="header_rpo" colspan="6" class="poptip over_header center not_sticky">RPO</th> <th aria-label="PlayAction" data-stat="header_play_action" colspan="2" class="poptip over_header center not_sticky">PlayAction</th> <th class="not_sticky"></th> </tr> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip center" data-tip="Rank">Rk</th> <th aria-label="Player" data-stat="name_display" scope="col" class=" poptip sort_default_asc center">Player</th> <th aria-label="Age" data-stat="age" scope="col" class=" poptip center" data-tip="As of Dec. 31 of the season in question.">Age</th> <th aria-label="Team" data-stat="team_name_abbr" scope="col" class=" poptip sort_default_asc center">Team</th> <th aria-label="Pos" data-stat="pos" scope="col" class=" poptip center" data-tip="Position">Pos</th> <th aria-label="G" data-stat="games" scope="col" class=" poptip center" data-tip="Games played">G</th> <th aria-label="GS" data-stat="games_started" scope="col" class=" poptip center" data-tip="Games started as an offensive or defensive player">GS</th> <th aria-label="Cmp" data-stat="pass_cmp" scope="col" class=" poptip center" data-tip="Passes completed">Cmp</th> <th aria-label="Att" data-stat="pass_att" scope="col" class=" poptip sort_col center" data-tip="Passes attempted">Att</th> <th aria-label="IAY" data-stat="pass_target_yds" scope="col" class=" poptip center" data-tip="Intended air yards - Air yards on all pass attempts, whether completed or incomplete">IAY</th> <th aria-label="IAY/PA" data-stat="pass_tgt_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Intended air yards per pass attempt - Average depth of target, whether completed or not" data-filter="1" data-name="">IAY/PA</th> <th aria-label="CAY" data-stat="pass_air_yds" scope="col" class=" poptip center" data-tip="Completed air yards - Total yards completed passes traveled in the air past the line of scrimmage before being caught">CAY</th> <th aria-label="CAY/Cmp" data-stat="pass_air_yds_per_cmp" scope="col" class=" poptip hide_non_quals center" data-tip="Completed air yards per completion - yards the ball traveled in the air past the line of scrimmage prior to a completion" data-filter="1" data-name="">CAY/Cmp</th> <th aria-label="CAY/PA" data-stat="pass_air_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Completed air yards per pass attempt - Air yards (on completed passes) per pass attempt" data-filter="1" data-name="">CAY/PA</th> <th aria-label="YAC" data-stat="pass_yac" scope="col" class=" poptip center" data-tip="Pass yards after catch">YAC</th> <th aria-label="YAC/Cmp" data-stat="pass_yac_per_cmp" scope="col" class=" poptip hide_non_quals center" data-tip="Pass yards after catch per completion" data-filter="1" data-name="">YAC/Cmp</th> <th aria-label="Bats" data-stat="pass_batted_passes" scope="col" class=" poptip center" data-tip="Passes batted by a defender at or behind the line of scrimmage">Bats</th> <th aria-label="ThAwy" data-stat="pass_throwaways" scope="col" class=" poptip center" data-tip="Passes thrown away">ThAwy</th> <th aria-label="Spikes" data-stat="pass_spikes" scope="col" class=" poptip center" data-tip="Passes spiked to stop the clock ">Spikes</th> <th aria-label="Drops" data-stat="pass_drops" scope="col" class=" poptip center" data-tip="Passes dropped">Drops</th> <th aria-label="Drop%" data-stat="pass_drop_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of passes dropped per pass attempt, excluding spikes and throwaways" data-filter="1" data-name="">Drop%</th> <th aria-label="BadTh" data-stat="pass_poor_throws" scope="col" class=" poptip center" data-tip="Poor throws">BadTh</th> <th aria-label="Bad%" data-stat="pass_poor_throw_pct" scope="col" class=" poptip sort_default_asc hide_non_quals center" data-tip="Percentage of poor throws per pass attempt, excluding spikes and throwaways" data-filter="1" data-name="">Bad%</th> <th aria-label="OnTgt" data-stat="pass_on_target" scope="col" class=" poptip center" data-tip="On-target throws, would have hit the intended receiver">OnTgt</th> <th aria-label="OnTgt%" data-stat="pass_on_target_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of on-target throws per pass attempt, excluding spikes and throwaways" data-filter="1" data-name="">OnTgt%</th> <th aria-label="PktTime" data-stat="pocket_time" scope="col" class=" poptip hide_non_quals center" data-tip="Average time the QB had in the pocket between the snap and throwing the ball or pressure collapses the pocket, in seconds" data-filter="1" data-name="">PktTime</th> <th aria-label="Bltz" data-stat="pass_blitzed" scope="col" class=" poptip center" data-tip="Times blitzed">Bltz</th> <th aria-label="Hrry" data-stat="pass_hurried" scope="col" clas